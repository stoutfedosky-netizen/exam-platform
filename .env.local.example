# Copy to .env.local and fill in from the Supabase dashboard:
# Project Settings -> API. .env.local is gitignored — never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY. Bypasses RLS. Never import into client code or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
